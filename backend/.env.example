# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/fitforge

# Server Configuration
PORT=3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (for reminders and password reset)
# Use Gmail SMTP (free) - Follow the setup instructions below:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to App Passwords: https://myaccount.google.com/apppasswords
# 4. Generate a new app password for "Mail" on "Other (Custom name)"
# 5. Use the 16-character password generated (without spaces)

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Note: Without EMAIL_USER and EMAIL_PASSWORD, the app will still work
# but email features (reminders, password reset) will be disabled
